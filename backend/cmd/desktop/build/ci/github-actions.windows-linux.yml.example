name: Desktop Release

on:
  workflow_dispatch:

jobs:
  build:
    strategy:
      matrix:
        include:
          - os: windows-latest
            label: windows
          - os: ubuntu-latest
            label: linux
    runs-on: ${{ matrix.os }}
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-go@v5
        with:
          go-version: '1.25'

      - uses: actions/setup-node@v4
        with:
          node-version: '22'

      - name: Install Wails CLI
        run: go install github.com/wailsapp/wails/v3/cmd/wails3@v3.0.0-alpha.40

      - name: Build control UI
        run: npm ci --prefix ui && npm run build --prefix ui

      - name: Stage control UI
        run: ./scripts/desktop/stage_control_ui.sh

      - name: Desktop build placeholder
        working-directory: backend/cmd/desktop
        run: |
          echo "Template only. Replace with active wails3 package + release:manifest commands after runtime-safe review."
          echo "Target platform: ${{ matrix.label }}"
          echo "Expected release outputs:"
          echo "  - bin/<platform artifacts>"
          echo "  - release/stable/update.json"
          echo "  - release/stable/SHA256SUMS"
